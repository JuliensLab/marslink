\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Schematic comparison of the three relay topologies (top-down heliocentric view). \textbf  {(a)}\nobreakspace  {}Hohmann-like: one eccentric transfer ring connects the Earth and Mars circular rings at perihelion and aphelion. \textbf  {(b)}\nobreakspace  {}Hybrid: $M$ eccentric rings with staggered arguments of perihelion improve coverage. \textbf  {(c)}\nobreakspace  {}Parallel: $R$ concentric circular rings create $N$ independent radial routes.\relax }}{1}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
